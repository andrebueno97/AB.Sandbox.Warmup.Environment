# Ignorar o arquivo .env com credenciais sensíveis
.env

# Ignorar arquivos de dados gerados pelo Docker Compose
# Para PostgreSQL
postgres_data/

# Para Redis
redis_data/

# Ignorar pastas de cache e logs (se houver)
cache/
logs/

# Ignorar arquivos e pastas específicos do sistema operacional
.DS_Store
thumbs.db

# Ignorar arquivos e pastas de IDEs (ex: VS Code)
.vscode/
.idea/

# Ignorar pacotes de dependências (se você tiver algum projeto que instale dependências localmente)
node_modules/
venv/
__pycache__/

# Ignorar pastas de build e compilação do .NET
bin/
obj/
*.dll
*.exe
*.pdb

# Ignorar arquivos de projeto Visual Studio / VS Code
.vs/
*.csproj.user
*.sln.user
*.suo

# Ignorar diretório de cache NuGet
.nuget/

# Ignorar arquivos de configuração local e secrets do .NET
appsettings.local.json
appsettings.development.local.json
appsettings.secrets.json
appsettings.secrets.example.json